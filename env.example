# Copy to .env.local for local dev. On Railway, set these in Variables (not in git).
RETELL_API_KEY=key_your_api_key_here
RETELL_AGENT_ID=agent_your_agent_id_here
NEXT_PUBLIC_SITE_URL=https://your-app-name.up.railway.app

# Server listens on PORT (Railway sets this automatically).
# HOSTNAME=0.0.0.0

# Register this URL in Retell (webhook) so call_analyzed events reach your app:
# POST https://your-domain/api/webhooks/retell
# Use the API key that shows the webhook badge for signature verification.

# Optional: email (separate feature)
# RESEND_API_KEY=re_xxxxxxxx
# EMAIL_FROM="MESON PANZA VERDE <onboarding@resend.dev>"
# FRONT_DESK_EMAIL=frontdesk@yourhotel.com
